        "additionalProperties": false
      },
      "ExportRequest": {
        "type": "object",
        "properties": {
          "exportPath": {
            "type": "string",
            "nullable": true
          },
          "includeStatisTable": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "LibraryRequest": {
        "type": "object",
