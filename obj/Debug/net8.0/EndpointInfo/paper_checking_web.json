          "errorPapers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CheckRequest": {
        "type": "object",
        "properties": {
          "checkWay": {
            "type": "integer",
            "format": "int32"
          },
          "checkThreshold": {
            "type": "integer",
            "format": "int32"
          },
          "recover": {
            "type": "boolean"
          },
          "toCheckPaperPath": {
            "type": "string",
            "nullable": true
          },
          "finalReportPath": {
            "type": "string",
            "nullable": true
          }
